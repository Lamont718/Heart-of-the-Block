# Heart of the Block — environment
# Copy to .env.local and fill in. The app runs without these (shell-only,
# logged-out) until they're set, so you can review before wiring Supabase.

# --- Supabase (Project Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Site URL (used for auth confirmation email links) ---
# Dev: http://localhost:3000   Prod: https://heartoftheblock.org
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Phase 2 (NOT used in v1; leave blank) ---
# ANTHROPIC_API_KEY=
# STRIPE_SECRET_KEY=
